{
  "manifest_version": 3,
  "name": "PDF Zoom Memory",
  "version": "1.0",
  "description": "Remembers your PDF zoom level and applies it to new PDFs",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*/*.pdf",
        "*://*/*.PDF",
        "*://*/*?*pdf*",
        "*://search.txcourts.gov/*",
        "*://*.hcdistrictclerk.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
