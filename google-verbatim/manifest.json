{
  "manifest_version": 3,
  "name": "Google Verbatim Search",
  "version": "1.0",
  "description": "Enforces verbatim results, no personalization, and no duplicate filtering on Google searches",
  "permissions": ["webNavigation", "tabs"],
  "host_permissions": ["https://www.google.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
