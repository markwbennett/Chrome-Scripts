{
    "manifest_version": 3,
    "name": "Fastmail Fixup",
    "version": "1.2",
    "content_scripts": [
      {
        "matches": ["*://*.fastmail.com/*"],
        "js": ["content.js"]
      }
    ],
    "action": {
      "default_popup": "popup.html",
      "default_title": "Fastmail Settings"
    },
    "permissions": ["activeTab", "storage"]
  }