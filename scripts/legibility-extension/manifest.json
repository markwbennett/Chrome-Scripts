{
  "manifest_version": 3,
  "name": "Texas Statutes Legibility",
  "version": "1.0",
  "description": "Improves readability of Texas statutes pages with better typography and dark theme",
  "permissions": [
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["https://statutes.capitol.texas.gov/*"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
} 