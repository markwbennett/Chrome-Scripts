{
  "manifest_version": 3,
  "name": "X Mass Blocker",
  "version": "1.0",
  "description": "Block all visible users on an X/Twitter search results page",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
